# PAO System Configuration Example
# Copy this file to .env and fill in your values

# WebSocket Server Configuration
PAO_WS_HOST=localhost
PAO_WS_PORT=8765

# Logging Configuration
PAO_LOG_LEVEL=INFO
PAO_LOG_FILE=pao_system.log

# Skill Management
PAO_SKILL_DIR=skills
PAO_SKILL_AUTO_UPDATE=true

# System Integration
PAO_INTEGRATION_ENABLED=true
PAO_INTEGRATION_TIMEOUT=30

# Protocol Configuration
PAO_PROTOCOL_DEFAULT=websocket
PAO_HEARTBEAT_INTERVAL=30
